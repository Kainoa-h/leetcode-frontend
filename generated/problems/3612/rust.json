          "sourceFilename": "3612_process_string_with_special_operations_I.rs",
          "code": "impl Solution {\n    pub fn process_str(s: String) -> String {\n        let mut result = String::new();\n\n        for c in s.chars() {\n            match c {\n                '*' => {\n                    result.pop();\n                }\n                '#' => {\n                    result += &result.clone();\n                }\n                '%' => {\n                    result = result.chars().rev().collect::<String>();\n                }\n                _ => {\n                    result.push(c);\n                }\n            }\n        }\n\n        result\n    }\n}\n\nstruct Solution {}\n",
