          "sourceFilename": "3300_minimum_element_after_replacement_with_digit_sum.rs",
          "code": "struct Solution {}\nimpl Solution {\n    pub fn min_element(nums: Vec<i32>) -> i32 {\n        let mut min = i32::MAX;\n        for n in nums {\n            let mut sum = 0;\n            let mut n = n;\n            while n != 0 {\n                sum += n % 10;\n                n /= 10;\n            }\n            min = min.min(sum);\n        }\n        min\n    }\n}\n\nfn main() {\n    assert_eq!(1, Solution::min_element(vec![10, 12, 13, 14]));\n}\n",
