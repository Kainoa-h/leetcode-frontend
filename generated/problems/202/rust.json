          "sourceFilename": "202_happy_number.rs",
          "code": "// all unhappy loops in base 10 end up at 4\nimpl Solution {\n    pub fn is_happy(mut n: i32) -> bool {\n        while n != 1 && n != 4 {\n            let mut acc = 0;\n            while n > 0 {\n                acc += (n % 10).pow(2);\n                n /= 10;\n            }\n            n = acc;\n        }\n        n == 1\n    }\n}\n\nstruct Solution {}\n",
