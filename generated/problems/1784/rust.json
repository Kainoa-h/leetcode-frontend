          "sourceFilename": "1784_check_if_binary_string_has_at_most_one_segment_of_ones.rs",
          "code": "struct Solution {}\n\nimpl Solution {\n    pub fn check_ones_segment(s: String) -> bool {\n        let mut in_sequence = true;\n        for c in s.bytes() {\n            if in_sequence {\n                if c == b'0' {\n                    in_sequence = false;\n                }\n            } else if c == b'1' {\n                return false;\n            }\n        }\n        true\n    }\n}\n\nfn main() {}\n",
