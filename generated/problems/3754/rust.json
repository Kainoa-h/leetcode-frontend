          "sourceFilename": "3754_concatenate_non_zero_digits_and_multiply_by_sum_I.rs",
          "code": "impl Solution {\n    pub fn sum_and_multiply(mut n: i32) -> i64 {\n        let mut arr = Vec::<i32>::new();\n        while n != 0 {\n            let digit = n % 10;\n            if digit != 0 {\n                arr.push(n % 10);\n            }\n            n /= 10;\n        }\n\n        let mut sum = 0;\n        let mut non_zero = 0;\n        let mut mul = 1;\n        for num in arr {\n            sum += num;\n            non_zero += num * mul;\n            mul *= 10;\n        }\n\n        sum as i64 * non_zero as i64\n    }\n}\n\nstruct Solution {}\n\nfn main() {\n    assert_eq!(Solution::sum_and_multiply(10203004), 12340);\n}\n",
