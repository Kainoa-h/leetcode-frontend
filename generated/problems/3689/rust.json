          "code": "impl Solution {\n    pub fn max_total_value(nums: Vec<i32>, k: i32) -> i64 {\n        let (min, max) = nums\n            .iter()\n            .skip(1)\n            .fold((&nums[0], &nums[0]), |(min, max), x| {\n                (min.min(x), max.max(x))\n            });\n        (max - min) as i64 * k as i64\n    }\n}\nstruct Solution {}\n",
