          "code": "struct Solution {}\nimpl Solution {\n    pub fn reverse_words(s: String) -> String {\n        s.split_whitespace().rev().collect::<Vec<&str>>().join(\" \")\n    }\n}\n\nfn main() {\n    println!(\n        \"'{}'\",\n        Solution::reverse_words(\"  a good   example  \".to_owned())\n    );\n}\n",
