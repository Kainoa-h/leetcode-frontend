          "sourceFilename": "3751_total_waviness_of_numbers_in_range.rs",
          "code": "struct Solution {}\nimpl Solution {\n    pub fn total_waviness(num1: i32, num2: i32) -> i32 {\n        let mut wavi = 0;\n        for num in num1..=num2 {\n            let v = Self::to_vec(num);\n            if v.len() < 3 {\n                continue;\n            }\n\n            for i in 1..v.len() - 1 {\n                if (v[i - 1] > v[i] && v[i + 1] > v[i]) || (v[i - 1] < v[i] && v[i + 1] < v[i]) {\n                    wavi += 1;\n                }\n            }\n        }\n        wavi\n    }\n\n    fn to_vec(mut n: i32) -> Vec<u8> {\n        let mut v = Vec::<u8>::new();\n        while n != 0 {\n            v.push((n % 10) as u8);\n            n = n / 10;\n        }\n        v\n    }\n}\n",
