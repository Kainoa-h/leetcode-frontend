          "sourceFilename": "26_remove_duplicates_from_sorted_array.rs",
          "code": "struct Solution {}\n\nimpl Solution {\n    pub fn remove_duplicates(nums: &mut Vec<i32>) -> i32 {\n        let mut real_idx = 1;\n        let mut prev_num = nums[0];\n        for i in 1..nums.len() {\n            let curr_num = nums[i];\n            if curr_num != prev_num {\n                nums[real_idx] = curr_num;\n                real_idx += 1;\n                prev_num = curr_num;\n            }\n        }\n        real_idx as i32\n    }\n}\n\nfn what(mut nums: Vec<i32>) {\n    println!(\"{:?}\", Solution::remove_duplicates(&mut nums));\n    println!(\"{:?}\", nums);\n}\n\nfn main() {\n    // Input: nums = [1,1,2]\n    // Output: 2, nums = [1,2,_]\n    what(vec![1, 1, 2]);\n\n    // Input: nums = [0,0,1,1,1,2,2,3,3,4]\n    // Output: 5, nums = [0,1,2,3,4,_,_,_,_,_]\n    what(vec![0, 0, 1, 1, 1, 2, 2, 3, 3, 4]);\n\n    what(vec![1, 1]);\n    what(vec![1]);\n}\n",
