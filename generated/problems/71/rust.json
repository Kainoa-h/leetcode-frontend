          "sourceFilename": "71_simplify_path.rs",
          "code": "impl Solution {\n    pub fn simplify_path(path: String) -> String {\n        let mut stack = Vec::new();\n        for subpath in path.split('/') {\n            match subpath {\n                \"..\" => { stack.pop(); },\n                \".\" | \"\" => {}\n                _ => stack.push(subpath)\n                \n            }\n        }\n        format!(\"/{}\", stack.join(\"/\"))\n    }\n}\n\nstruct Solution {}\n\nfn main() {\n    Solution::simplify_path(\"\".to_string());\n}\n",
