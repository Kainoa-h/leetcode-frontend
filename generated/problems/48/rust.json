          "code": "struct Solution {}\nimpl Solution {\n    pub fn rotate(matrix: &mut Vec<Vec<i32>>) {\n        for i in 0..matrix.len() {\n            for j in i..matrix.len() {\n                (matrix[i][j], matrix[j][i]) = (matrix[j][i], matrix[i][j]);\n            }\n            matrix[i].reverse();\n        }\n    }\n}\n\nfn main() {\n    println!(\"i ain't writing a test for this\");\n}\n",
