---
import Base from '../../../layouts/Base.astro';
import { index } from '../../../lib/data';
export function getStaticPaths() {
  return index.questions.map((question) => ({
    params: { id: String(question.id) },
    props: { question },
  }));
}
const { question } = Astro.props;
---

<Base title={`${question.id}. ${question.title}`}
  ><nav><a href="/">← All questions</a></nav><header class="page-header">
    <p class="eyebrow">Problem {question.id}</p><h1>{question.title}</h1><p>
      {question.languages.length} language-specific {
        question.languages.length === 1 ? 'history' : 'histories'
      }
    </p>
  </header><section>
    <h2>Languages</h2><div class="language-grid">
      {
        question.languages.map((l) => (
          <a class="language-card" href={l.route}>
            <span>{l.approachCount} approaches</span>
            {l.incorrectRevisionCount > 0 && (
              <span class="wrong">
                {l.incorrectRevisionCount} marked incorrect
              </span>
            )}
            <small>
              {question.firstCommittedAt &&
                new Date(question.firstCommittedAt).toLocaleDateString(
                  'en-CA',
                )}{' '}
              →{' '}
              {l.lastCommittedAt &&
                new Date(l.lastCommittedAt).toLocaleDateString('en-CA')}
            </small>
          </a>
        ))
      }
    </div>
  </section></Base
>
