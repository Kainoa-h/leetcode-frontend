---
import type { SolutionRevision } from '../../scripts/lib/schemas';
import { highlight } from '../lib/highlight';
import { sourceUrl } from '../lib/data';
const { revision, language } = Astro.props as {
  revision: SolutionRevision;
  language: string;
};
const full = await highlight(revision.code, language);
const diff = revision.diffFromPreviousRelevantRevision
  ? await highlight(revision.diffFromPreviousRelevantRevision, 'diff')
  : null;
---

<article class:list={['revision', revision.markedWrong && 'incorrect']}>
  <header>
    <div>
      <a href={sourceUrl(revision.sha)}><code>{revision.shortSha}</code></a>{
        revision.markedWrong && (
          <span class="wrong-badge">! Marked incorrect by the author</span>
        )
      }
    </div><p>{revision.shortChangeSummary}</p><small
      >Chronological #{revision.chronologicalIndex + 1} · Narrative #{
        revision.narrativeIndex + 1
      } · <time datetime={revision.committedAt}
        >{new Date(revision.committedAt).toLocaleString('en-CA')}</time
      ></small
    ><small
      ><a href={sourceUrl(revision.sha, revision.sourcePath)}
        >{revision.sourceFilename}</a
      >{revision.commitComment && <> · {revision.commitComment}</>}</small
    ><div class="actions">
      {
        diff && (
          <button type="button" data-toggle>
            Show diff
          </button>
        )
      }<button type="button" data-copy>Copy code</button>
    </div>
  </header><div class="code-view full" set:html={full} />{
    diff && <div class="code-view diff" hidden set:html={diff} />
  }<textarea hidden data-source>{revision.code}</textarea>
</article>
